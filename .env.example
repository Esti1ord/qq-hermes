QQ_DOCS_FIREFOX_COOKIES=/home/roxy/snap/firefox/common/.mozilla/firefox/oc6jt8qq.default/cookies.sqlite
QQ_DOCS_PEOPLE_DOC_URL=https://docs.qq.com/markdown/DV3ZkWmV3bFRidnhj?
QQ_DOCS_PEOPLE_FILE_ID=
QQ_DOCS_PEOPLE_TARGET=/home/roxy/qq-hermes/groups/975805598/people.md
QQ_DOCS_PEOPLE_STATE=/home/roxy/qq-hermes/groups/975805598/.people-doc-sync-state.json
QQ_DOCS_PEOPLE_BACKUP_DIR=/home/roxy/qq-hermes/groups/975805598/backups
