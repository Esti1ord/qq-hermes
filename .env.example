# ============================================================================
# QQ Hermes Bridge Configuration
# ============================================================================
# Copy this file to .env and adjust values for your local setup.
# Do NOT commit .env - it contains secrets and local paths.
#
# Precedence: shell/systemd env vars > .env > code defaults
# ============================================================================

# ============================================================================
# Basic Setup
# ============================================================================

# Project paths
QQ_HERMES_BASE_DIR=/home/roxy/qq-hermes
QQ_HERMES_PYTHON=/home/roxy/qq-hermes/venv/bin/python

# Bridge HTTP server
QQ_HERMES_HOST=0.0.0.0
QQ_HERMES_PORT=8765
QQ_HERMES_APP=bridge:app
BRIDGE_URL=http://127.0.0.1:8765/health

# Bot identity
BOT_QQ=3975680980

# Groups configuration
# TARGET_GROUP_ID: Primary/default group for fallback values
TARGET_GROUP_ID=975805598
# GROUP_IDS: Comma-separated allow-list of groups the bot can read/reply in
GROUP_IDS=975805598,781423661
GROUP_CONFIG_DIR=/home/roxy/qq-hermes/groups
GROUP_LIST_FILE=/home/roxy/qq-hermes/groups/groups.txt

# Base persona file (optional, can use per-group persona.md instead)
BASE_PERSONA_FILE=/home/roxy/qq-hermes/groups/_templates/base_persona.md.example
# Legacy overrides - usually leave empty and use groups/<group_id>/ files
PERSONA_FILE=
PEOPLE_FILE=

# ============================================================================
# OneBot / NapCat Integration
# ============================================================================

# NapCat OneBot HTTP API endpoint
ONEBOT_HTTP_URL=http://127.0.0.1:3000

# OneBot HTTP API token (if NapCat requires authentication)
# Leave empty if NapCat server doesn't use token auth
ONEBOT_ACCESS_TOKEN=

# Bridge inbound webhook token (optional security layer)
# When set, OneBot must send Authorization: Bearer <token> or X-Bridge-Token: <token>
BRIDGE_INBOUND_TOKEN=

# Reply prefix (optional, usually leave empty)
REPLY_PREFIX=

# ============================================================================
# Hermes CLI Integration
# ============================================================================

# Hermes binary and home directory
HERMES_BIN=/home/roxy/.local/bin/hermes
HERMES_HOME=/home/roxy/.hermes

# Default model and provider
HERMES_MODEL=gpt-5.5
HERMES_PROVIDER=openai-gpt

# Per-group model/provider overrides
# Format: <group_id>=<value>,<group_id>=<value>
# Example: route group 781423661 to DeepSeek, keep others on OpenAI
HERMES_MODEL_BY_GROUP=
HERMES_PROVIDER_BY_GROUP=

# Hermes call timeout (seconds)
HERMES_TIMEOUT=180

# Group session management
# When enabled, each group gets persistent session: qq-group-<group_id>
HERMES_GROUP_SESSIONS_ENABLED=true
HERMES_GROUP_SESSION_PREFIX=qq-group

# Session auto-compaction to prevent token bloat
HERMES_SESSION_AUTOCOMPACT_ENABLED=true
HERMES_SESSION_MAX_MESSAGES=80
HERMES_SESSION_MAX_BODY_CHARS=180000
HERMES_SESSION_COMPACT_SUMMARY_CHARS=1200

# ============================================================================
# Prompt and Reply Behavior
# ============================================================================

# Prompt and reply length limits
MAX_PROMPT_CHARS=3500
MAX_REPLY_CHARS=450

# Punctuation style: reduce periods/commas for natural group chat feel
PUNCTUATION_STYLE_ENABLED=true

# Knowledge file character limit
KNOWLEDGE_MAX_CHARS=3500

# Reply timing and rate limits
MIN_SECONDS_BETWEEN_REPLIES=2
USER_COOLDOWN_SECONDS=20
MAX_PENDING_REPLIES=3

# Mention handling
SKIP_UNCLEAR_MENTIONS=true

# Profile matching for /context queries
RELATED_PROFILE_MAX_MATCHES=3
RELATED_PROFILE_MIN_KEYWORD_LEN=2

# ============================================================================
# Context Management
# ============================================================================

# Recent context window
CONTEXT_MAX_MESSAGES=20
CONTEXT_MAX_CHARS_PER_MESSAGE=300

# Context summarization
CONTEXT_SUMMARIZE_ENABLED=true
CONTEXT_SUMMARY_MAX=30
CONTEXT_SUMMARIZE_BATCH=10
CONTEXT_SUMMARY_MAX_CHARS=240

# Context persistence to disk
CONTEXT_PERSIST_ENABLED=true
CONTEXT_CACHE_FILE=/home/roxy/qq-hermes/logs/recent_context.jsonl

# ============================================================================
# OCR / Image Recognition (Disabled by Default)
# ============================================================================

# Enable image recognition
OCR_ENABLED=false

# Trigger modes:
# - direct_only: Only recognize images in @bot or reply-to-bot messages
# - direct_and_context: Also recognize images in ordinary group messages (async)
# - context_only: Only async context recognition
# - all: Recognize in all allowed message types
OCR_TRIGGER_MODE=direct_only

# Groups for async context OCR (when trigger_mode includes context)
OCR_CONTEXT_GROUP_IDS=

# OCR provider
# - model: OpenAI-compatible model vision API (requires OCR_EXTERNAL_PROVIDER_ALLOWED=true)
# - hermes: Use Hermes CLI with --image (requires OCR_EXTERNAL_PROVIDER_ALLOWED=true)
# - mock: Mock provider for testing
# - none: Disabled
OCR_PROVIDER=model

# External provider permission (required for hermes/online services)
# Set to true to allow sending images to external APIs
OCR_EXTERNAL_PROVIDER_ALLOWED=false

# Model provider settings (no real secrets here)
# OCR_MODEL: vision-capable model name, e.g. gpt-4o-mini
# OCR_PROVIDER_BASE_URL: provider base URL or chat/completions endpoint
# OCR_API_KEY_ENV: env var containing the API key value, not the key itself
OCR_MODEL=
OCR_PROVIDER_BASE_URL=
OCR_API_KEY_ENV=

# Image constraints
OCR_MAX_IMAGES_PER_MESSAGE=2
OCR_MAX_BYTES_PER_IMAGE=6291456
OCR_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif

# Timeouts
OCR_DOWNLOAD_TIMEOUT=8
OCR_PROVIDER_TIMEOUT=30

# OCR result handling
OCR_MAX_RESULT_CHARS=800
OCR_IMAGE_PROMPT=请理解这张图片并转换成给群聊机器人使用的文字上下文：先描述画面/截图/人物/物体/场景/表情包含义，再提取可见文字；如果是聊天截图或梗图，请概括核心内容和语气。不要只做OCR，不要编造看不清的细节。

# OCR concurrency and caching
OCR_MAX_CONCURRENT_TASKS=2
OCR_CACHE_TTL_SECONDS=3600
OCR_CACHE_MAX_ENTRIES=512

# Include OCR results in prompt/context
OCR_INCLUDE_IN_PROMPT=true
OCR_INCLUDE_IN_CONTEXT=true

# Persist OCR text in context files (privacy consideration)
OCR_PERSIST_TEXT_IN_CONTEXT=false

# Deprecated debug toggles retained for compatibility. Runtime logs remain content-safe
# and do not include raw OCR text or full image URLs.
OCR_LOG_TEXT=false
OCR_LOG_IMAGE_URLS=false

# ============================================================================
# Self-Learning System (Disabled by Default)
# ============================================================================
# Collects group-specific samples to learn local slang, tone words, and style.
# Stores data in groups/<group_id>/self_learning.json (private, do not commit).
#
# Privacy notes:
# - Only enabled for explicitly listed groups
# - Samples are filtered (no commands, no bot replies, no sensitive keywords)
# - Generates statistical hints, not verbatim quotes
# - Low-weight prompt injection, doesn't override current context

# Master switches
SELF_LEARNING_ENABLED=false
SELF_LEARNING_COLLECT_ENABLED=false
SELF_LEARNING_INJECT_ENABLED=false

# Allowed groups (comma-separated)
SELF_LEARNING_ALLOWED_GROUP_IDS=

# Sample collection filters
SELF_LEARNING_MIN_MESSAGE_CHARS=2
SELF_LEARNING_MAX_MESSAGE_CHARS=300

# Sample retention
SELF_LEARNING_MAX_SAMPLES_PER_GROUP=500
SELF_LEARNING_RETENTION_DAYS=30

# Prompt injection limits
SELF_LEARNING_MAX_PROMPT_CHARS=500
SELF_LEARNING_MIN_COUNT_FOR_PROMPT=3

# Data file name
SELF_LEARNING_DATA_FILENAME=self_learning.json

# ============================================================================
# Proactive Speaking
# ============================================================================
# Bot can proactively reply to messages without being @mentioned.
# Controlled by heat score, cooldowns, and daily limits.

# Enable proactive speaking
PROACTIVE_ENABLED=true

# Default heat threshold (0-100, higher = less chatty)
PROACTIVE_TRIGGER_THRESHOLD=16

# Per-group overrides (format: <group_id>=<threshold>)
# Example: 781423661=999 effectively disables proactive for that group
PROACTIVE_TRIGGER_THRESHOLDS_BY_GROUP=

# Rate limiting
PROACTIVE_GROUP_COOLDOWN_SECONDS=20
PROACTIVE_DAILY_LIMIT_PER_GROUP=80
PROACTIVE_RATE_LIMIT_WINDOW_SECONDS=60
PROACTIVE_RATE_LIMIT_MAX_REPLIES=10

# Heat score decay
PROACTIVE_DECAY_PER_MINUTE=1

# Context windows for proactive evaluation
PROACTIVE_CONTEXT_FOCUS_MESSAGES=3
PROACTIVE_CONTEXT_MEMORY_MESSAGES=8

# Burst detection (multiple users chatting actively)
PROACTIVE_BURST_WINDOW_SECONDS=120
PROACTIVE_BURST_MESSAGE_THRESHOLD=6
PROACTIVE_BURST_USER_THRESHOLD=3

# Trigger keywords and scores
PROACTIVE_NAME_TRIGGERS=Esti,Estilord,Esti1ord,机器人,bot,小E
PROACTIVE_TOPIC_KEYWORDS=精神状态,吃什么,南航,中大,联谊,实习,秋招,保研,考研,游戏,开黑
PROACTIVE_LIGHT_KEYWORDS=笑死,绷不住,服了,寄,困,累,无聊

PROACTIVE_SCORE_NAME_TRIGGER=10
PROACTIVE_SCORE_TOPIC_KEYWORD=4
PROACTIVE_SCORE_LIGHT_KEYWORD=2
PROACTIVE_SCORE_QUESTION=2
PROACTIVE_SCORE_OPEN_QUESTION=4
PROACTIVE_SCORE_BURST=4
PROACTIVE_SCORE_MULTI_USER=3

# Sensitive content cooldown
PROACTIVE_SENSITIVE_COOLDOWN_SECONDS=1800
PROACTIVE_SENSITIVE_KEYWORDS=密码,验证码,账号,诈骗,开盒,身份证,裸照

# Night mode (reduced activity during specified hours)
PROACTIVE_NIGHT_START=00:30
PROACTIVE_NIGHT_END=08:30
PROACTIVE_NIGHT_SCORE_MULTIPLIER=0.2

# ============================================================================
# Web Search and /deepseek Command
# ============================================================================

# /search command
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT=45
WEB_SEARCH_MAX_CHARS=1200
WEB_SEARCH_BACKEND=curl
WEB_SEARCH_PROVIDER=deepseek
WEB_SEARCH_MODEL=deepseek-v4-flash
WEB_SEARCH_HTTP_TIMEOUT=8
WEB_SEARCH_MAX_SUCCESSFUL_FETCHES=3
WEB_SEARCH_NOTICE_ENABLED=true
WEB_SEARCH_NOTICE_TEXT=我先联网查一下

# /deepseek command (deep analysis with web search)
DEEPSEEK_COMMAND_PROVIDER=openai-gpt
DEEPSEEK_COMMAND_MODEL=gpt-5.5

# ============================================================================
# Logging and Analytics
# ============================================================================

# Runtime statistics (content-safe: counts, latencies, hashes only)
RUNTIME_STATS_ENABLED=true
RUNTIME_STATS_FILE=/home/roxy/qq-hermes/logs/runtime_stats.jsonl
RUNTIME_STATS_USER_HASH_SALT=
RUNTIME_STATS_SUMMARY_INTERVAL_SECONDS=300

# Prometheus-compatible /metrics endpoint (content-safe; group_id label disabled by default)
PROMETHEUS_ENABLED=true
PROMETHEUS_INCLUDE_GROUP_ID_LABEL=false

# Performance observability (uses runtime_stats.jsonl)
PERF_OBS_ENABLED=true
PERF_OBS_DETAIL_LEVEL=standard
PERF_OBS_SAMPLE_RATE=1.0
PERF_OBS_SLOW_REPLY_MS=15000
PERF_OBS_SLOW_HERMES_MS=10000
PERF_OBS_SLOW_SEND_MS=3000
PERF_OBS_SLOW_OCR_MS=8000
PERF_OBS_SLOW_SEARCH_MS=10000
PERF_OBS_INTERACTION_TTL_SECONDS=3600
PERF_OBS_MAX_INTERACTIONS=2000

# Content analysis log (WARNING: contains real chat text)
# Keep local, review before sharing, never commit
CONTENT_ANALYSIS_LOG_ENABLED=true
CONTENT_ANALYSIS_LOG_FILE=/home/roxy/qq-hermes/logs/content_analysis.jsonl
CONTENT_ANALYSIS_ALLOWED_GROUP_IDS=
CONTENT_ANALYSIS_CONTEXT_MESSAGES=8
CONTENT_ANALYSIS_MAX_TEXT_CHARS=1000
CONTENT_ANALYSIS_MAX_REPLY_CHARS=1000
CONTENT_ANALYSIS_INCLUDE_SUMMARIES=true

# ============================================================================
# JRRP (今日人品)
# ============================================================================

JRRP_STATE_FILE=/home/roxy/qq-hermes/logs/jrrp_state.json
JRRP_RESULTS_FILE=/home/roxy/qq-hermes/jrrp_results.json

# ============================================================================
# NapCat Docker Configuration
# ============================================================================

NAPCAT_ACCOUNT=3975680980
NAPCAT_WEBUI_TOKEN=
NAPCAT_WEBUI_PREFIX=/webui
NAPCAT_CONTAINER_NAME=napcat
NAPCAT_CONTAINER=napcat
NAPCAT_HOSTNAME=desktop-48c50d740a70
NAPCAT_MAC_ADDRESS=02:c2:0e:1c:42:03
NAPCAT_IMAGE=mlikiowa/napcat-docker:v4.10.47
DOCKER=docker

# ============================================================================
# QQ Docs Sync (Optional)
# ============================================================================
